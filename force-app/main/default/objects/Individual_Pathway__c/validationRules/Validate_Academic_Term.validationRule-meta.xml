<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Academic_Term</fullName>
    <active>true</active>
    <description>To ensure the selected academic term is valid.</description>
    <errorConditionFormula>NOT(ISBLANK( Academic_Term__c )) &amp;&amp;  Academic_Term__r.RecordType.DeveloperName != &apos;Academic_Term&apos;</errorConditionFormula>
    <errorDisplayField>Academic_Term__c</errorDisplayField>
    <errorMessage>Please select a valid academic term.</errorMessage>
</ValidationRule>
