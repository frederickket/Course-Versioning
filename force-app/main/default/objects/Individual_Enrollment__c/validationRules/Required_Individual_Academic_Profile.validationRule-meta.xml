<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_Individual_Academic_Profile</fullName>
    <active>true</active>
    <description>To ensure that the individual enrollment has an individual academic profile selected.</description>
    <errorConditionFormula>AND(
    ISBLANK(Individual_Academic_Profile__c),
    $RecordType.DeveloperName = &quot;Student&quot;
)</errorConditionFormula>
    <errorDisplayField>Individual_Academic_Profile__c</errorDisplayField>
    <errorMessage>The Individual Academic Profile is required.</errorMessage>
</ValidationRule>
