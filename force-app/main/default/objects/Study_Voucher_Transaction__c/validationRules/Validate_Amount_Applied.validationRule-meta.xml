<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Amount_Applied</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
NOT(ISBLANK(Amount_Applied__c)),
NOT(ISBLANK(Amount__c)),
Amount_Applied__c &gt; Amount__c
)</errorConditionFormula>
    <errorDisplayField>Amount_Applied__c</errorDisplayField>
    <errorMessage>The study voucher transaction has exceeded its amount limit.</errorMessage>
</ValidationRule>
