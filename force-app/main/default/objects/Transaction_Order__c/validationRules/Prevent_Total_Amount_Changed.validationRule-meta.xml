<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Total_Amount_Changed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &apos;Confirmed&apos;),
    ISCHANGED( Total_Amount__c ) 
)</errorConditionFormula>
    <errorMessage>You cannot update the amount because the Transaction Order Status is set to Confirmed.</errorMessage>
</ValidationRule>
