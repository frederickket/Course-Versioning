<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_ItemType</fullName>
    <active>true</active>
    <description>To ensure the item type is set.</description>
    <errorConditionFormula>ISBLANK(TEXT( Item_Type__c )) &amp;&amp;  ISPICKVAL(Transaction_Type__c, &quot;Order Line&quot;)</errorConditionFormula>
    <errorDisplayField>Item_Type__c</errorDisplayField>
    <errorMessage>Please select an item type.</errorMessage>
</ValidationRule>
