        <rules>
            <name>Has_SFD_Max_Amount</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Selected_Individual_Funding_Allocations.Study_Funding__r.Max_Per_Term__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_IFA_Amount_To_SFD</targetReference>
            </connector>
            <label>Has SFD Max Amount</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if the study funding is repayable.</description>
        <name>Is_Repayable_Funding</name>
        <label>Is Repayable Funding?</label>
        <locationX>891</locationX>
        <locationY>2174</locationY>
        <defaultConnector>
            <targetReference>Set_Transaction_Type_Non_Repayable</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Repayable_Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Selected_Individual_Funding_Allocations.Study_Funding__r.Repayable__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Transaction_Type_Repayable</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
