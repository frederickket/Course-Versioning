    <decisions>
        <description>Validate the amount option selected by user to decide the default amount value.</description>
        <name>Check_Amount_Option</name>
        <label>Check Amount Option</label>
        <locationX>891</locationX>
        <locationY>1190</locationY>
        <defaultConnector>
            <targetReference>Set_IFA_Amount_With_Remaining_Amount</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Remaining Amount</defaultConnectorLabel>
        <rules>
            <name>AmountOption_Is_Max_Term</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>S3_Options_for_Amount_Radio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Max_Term_or_Remaining_Amount</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Max_Per_Term</targetReference>
            </connector>
            <label>Is Max Term</label>
        </rules>
        <rules>
            <name>AmountOption_Is_Custom_Amount</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>S3_Options_for_Amount_Radio</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Custom_Amount</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_IFA_Amount_With_Custom_Amount</targetReference>
            </connector>
            <label>Is Custom Amount</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check the max per term in individual funding allocation.</description>
        <name>Check_Max_Per_Term</name>
        <label>Check Max Per Term</label>
        <locationX>462</locationX>
        <locationY>1298</locationY>
        <defaultConnector>
            <targetReference>Check_Study_Funding_Max_Per_Term</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Max Amount</defaultConnectorLabel>
        <rules>
            <name>Has_Max_Amount</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Selected_Individual_Funding_Allocations.Max_Per_Term__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_IFA_Amount_With_Max_Term_Amount</targetReference>
            </connector>
            <label>Has Max Amount</label>
        </rules>
    </decisions>
    <decisions>
        <description>To check the amount to be disbursed against the remaining amount to ensure we don&apos;t over disburse.</description>
        <name>Check_Remaining_Amount_Available</name>
        <label>Check Remaining Amount Available</label>
        <locationX>891</locationX>
        <locationY>1874</locationY>
        <defaultConnector>
            <targetReference>Set_IFA_Amount_With_Remaining_Amount_2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Insufficient</defaultConnectorLabel>
        <rules>
            <name>Amount_Sufficient</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Selected_Individual_Funding_Allocations.Remaining_Amount__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>ifaAmount</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Repayable_Funding</targetReference>
            </connector>
            <label>Sufficient</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check the max per term defined in study funding if the individual funding allocation doesn&apos;t have one.</description>
        <name>Check_Study_Funding_Max_Per_Term</name>
        <label>Check Study Funding Max Per Term</label>
        <locationX>660</locationX>
        <locationY>1406</locationY>
        <defaultConnector>
