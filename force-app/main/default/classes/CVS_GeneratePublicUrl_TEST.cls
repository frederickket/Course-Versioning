@IsTest
public inherited sharing class CVS_GeneratePublicUrl_TEST {

    /**
     * @description Initialise test environment
     */
    static REDU_TestData_FACTORY testFactory = new REDU_TestData_FACTORY();

    /**
     * @description Create settings and test data
     */
	@TestSetup
    static void makeData() {
		
        // Create settings
		testFactory.setupDefaultSettings();
    }

    /**
     * @description Test generate public URL after insert as admin user
     */
    @IsTest
    static void testGeneratePublicURLAfterInsertAsAdminUser() {
        
        User ADMIN_USER = testFactory.getReduAdminUser();
        
        System.runAs(ADMIN_USER) {
            Test.startTest();

            //Create File 
            Blob body = Blob.valueOf('data:image/gif;base64,');
            ContentVersion cvs = new ContentVersion();
            cvs.Title = 'testGenerateUrl.png';
            cvs.VersionData = body;
            cvs.PathOnClient = '/' + cvs.Title;
            cvs.reduivy__Generate_Public_URL__c = true;
            insert cvs;

            //Assert public url
            ContentVersion checkCvs = [SELECT Id, reduivy__Public_URL__c, reduivy__Generate_Public_URL__c FROM ContentVersion WHERE Id = :cvs.Id];
            System.Assert.isTrue(String.isNotBlank(checkCvs.reduivy__Public_URL__c), 'Should have created public url');
            String publicUrl = checkCvs.reduivy__Public_URL__c;

            //Create Url again
            checkCvs.reduivy__Generate_Public_URL__c = false;
            checkCvs.reduivy__Public_URL__c = null;
            update checkCvs;
            checkCvs.reduivy__Generate_Public_URL__c = true;
            update checkCvs;

            //Assert public url has not changed
            checkCvs = [SELECT Id, reduivy__Public_URL__c FROM ContentVersion WHERE Id = :cvs.Id];
            System.Assert.areEqual(publicUrl, checkCvs.reduivy__Public_URL__c, 'Should have re-used existing public url');
            
            Test.stopTest();
        }
	}

