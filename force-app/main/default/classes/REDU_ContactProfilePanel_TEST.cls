    /**
     * @description Initialise test environment
     */
    static REDU_TestData_FACTORY testFactory = new REDU_TestData_FACTORY();

    @TestSetup
    static void makeData(){
        // Create settings
        testFactory.setupDefaultSettings();
    }

    /**
     * @description Test get profile picture as admin
     */
    @IsTest
    static void testGetProfilePictureAsAdmin(){
        User ADMIN_USER = testFactory.getReduAdminUser();
        
        System.runAs(ADMIN_USER) {
            //Setup
            Contact con = new Contact(LastName = 'Test Contact');
            insert con;

            Blob body = Blob.valueOf('data:image/gif;base64,');
            String fileName = 'testImage' + String.valueOf(system.today()) + '.png';

            ContentVersion cv = new ContentVersion(Title = fileName, VersionData = body, PathOnClient='/' + fileName, reduivy__File_Category__c = 'Profile Picture'); 
            insert cv;
            
            cv = [SELECT ContentDocumentId FROM ContentVersion WHERE Id = :cv.Id];
            insert new ContentDocumentLink(ContentDocumentId = cv.ContentDocumentId, ShareType = 'V', LinkedEntityId = con.Id);

            //Test
            Test.startTest();
            REDU_LightningResponse response = REDU_ContactProfilePanel_LCTRL.getProfilePicture(con.Id, 'Profile Picture');
            Test.stopTest();

            //Assert results
            System.Assert.isTrue(response.isSuccess);

            Map<String, Object> responseData = (Map<String, Object>) JSON.deserializeUntyped(response.responseData);
            Map<String, Object> cvResponseMap = (Map<String, Object>) responseData.get('contentVersion');
            Id cvResponseId = (String) cvResponseMap.get('Id');
            System.Assert.areEqual(cv.Id, cvResponseId);

            String avatarResourceUrl = REDU_AppSetting_UTIL.getFileRenditionUrl();
            System.Assert.areEqual(String.format(avatarResourceUrl, new List<String>{cv.Id, cv.ContentDocumentId}), responseData.get('imageUrl'));
        }
    }

