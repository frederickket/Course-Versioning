            //Test
            Test.startTest();
            REDU_LightningResponse response = REDU_ContactProfilePanel_LCTRL.deleteProfilePicture(con.Id, 'Profile Picture');
            Test.stopTest();

            //Assert results
            System.Assert.isTrue(response.isSuccess);

            //Assert file is deleted
            Boolean fileDeleted = false;
            try {
                ContentDocument deletedCd = [SELECT Id FROM ContentDocument WHERE Id = :cv.ContentDocumentId];
            } catch (QueryException e) {
                fileDeleted = true;
            }

            System.Assert.isTrue(fileDeleted, 'File should be deleted');
        }
    }

