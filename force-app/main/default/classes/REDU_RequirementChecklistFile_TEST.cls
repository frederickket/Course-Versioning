	@TestSetup
    static void makeData(){
        
        // Create settings
        testFactory.setupDefaultSettings();

        // Create test data
        User ADMIN_USER = testFactory.getReduAdminUser();
		System.runAs(ADMIN_USER) {
            Test.startTest();
        	
            testFactory.initMasterData(SRQ_Helper.getApiName());
            testFactory.initOfferingData(SIT_Helper.getApiName());
            testFactory.initFacultyData(USR_Helper.getApiName(), true);
            testFactory.initStudentData(IRQ_Helper.getApiName(), true);
            
            Test.stopTest();
		}

    }

    /**
     * @description Test as admin for getExistingUploadedFiles
     */
    @IsTest
    static void testForGetExistingUploadedFilesAsAdmin() {

        Blob body = Blob.valueOf('data:image/gif;base64,');
        
        ContentVersion cvs1 = new ContentVersion();
        cvs1.Title = 'TestFileCategorySharing1.png';
        cvs1.VersionData = body;
        cvs1.PathOnClient = '/' + cvs1.Title;
        cvs1.reduivy__File_Category__c = 'Transcript';

        User ADMIN_USER = testFactory.getReduAdminUser();

        //reduivy__Individual_Program_Application__c ipa = queryIpa();
        reduivy__Individual_Requirement__c irq = queryIrq();

		System.runAs(ADMIN_USER){
            insert cvs1;
        }

        ContentVersion insertedCvs = [SELECT Id, ContentDocumentId FROM ContentVersion WHERE Id = :cvs1.Id];

        ContentDocumentLink irqCdl = new ContentDocumentLink();
        irqCdl.ContentDocumentId = insertedCvs.ContentDocumentId;
        irqCdl.LinkedEntityId = irq.Id;
        irqCdl.ShareType = 'V';
        irqCdl.Visibility = 'InternalUsers';

        insert irqCdl;

        Test.startTest();
        
		System.runAs(ADMIN_USER){
            REDU_LightningResponse response = REDU_RequirementChecklistFile_LCTRL.getExistingUploadedFiles(irq.Id);
            List<ContentDocument> actualResult = (List<ContentDocument>) JSON.deserialize(response.responseData, List<ContentDocument>.class);
            System.Assert.areEqual(1, actualResult.size(), 'Wrong content document list size!');
            
		}

        Test.stopTest();
		
    }
	
    /**
